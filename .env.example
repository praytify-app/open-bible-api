# Database
DATABASE_URL=postgresql://bible:bible@localhost:5433/open_bible

# API Security
ADMIN_TOKEN=your-admin-token-here

# Server
PORT=3100
HOST=0.0.0.0

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# Rate Limiting (requests per minute)
RATE_LIMIT=100

# api.bible API key (for copyrighted versions: ESV, NIV, NLT, NASB, NKJV)
# Get a free key at https://scripture.api.bible/
API_BIBLE_KEY=
