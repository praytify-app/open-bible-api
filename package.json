{
  "name": "open-bible-api",
  "version": "1.0.0",
  "description": "Open-source REST API serving Bible data",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/seeder/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["bible", "api", "rest", "hono"],
  "author": "Open Bible API Contributors",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
